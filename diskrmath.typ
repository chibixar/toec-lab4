== Задание 6.1.1. Дешифратор кодовой комбинации
*Условие:* Построить дешифратор для кодовой комбинации $alpha = "yxxyyxxy"$. Входной алфавит $\{ x, y \}$.

*Решение:*
Дешифратор — это конечный автомат, который выдает сигнал "1" только в момент успешного считывания всей заданной последовательности символов, и "0" во всех остальных случаях. 
Построим граф переходов автомата. Состояния $q_1 ... q_9$ отражают длину успешно прочитанного префикса искомого слова (от 0 до 8). 
Любой ошибочный символ возвращает автомат назад — в то состояние, которое соответствует максимальному совпавшему суффиксу из введенных символов.

#align(center)[
  #cetz.canvas({
    import cetz.draw: *
    let r = 0.35
    
    // Располагаем узлы в линию для наглядного отображения "успешного пути"
    circle((0,0), radius: r, name: "q1"); content("q1", $q_1$)
    circle((2,0), radius: r, name: "q2"); content("q2", $q_2$)
    circle((4,0), radius: r, name: "q3"); content("q3", $q_3$)
    circle((6,0), radius: r, name: "q4"); content("q4", $q_4$)
    circle((8,0), radius: r, name: "q5"); content("q5", $q_5$)
    circle((10,0), radius: r, name: "q6"); content("q6", $q_6$)
    circle((12,0), radius: r, name: "q7"); content("q7", $q_7$)
    circle((14,0), radius: r, name: "q8"); content("q8", $q_8$)
    circle((16,0), radius: r, name: "q9"); content("q9", $q_9$)

    // Главная успешная цепь (сверху): y - x - x - y - y - x - x - y
    line("q1", "q2", mark: (end: ">")); content((1, 0.3), $y | 0$)
    line("q2", "q3", mark: (end: ">")); content((3, 0.3), $x | 0$)
    line("q3", "q4", mark: (end: ">")); content((5, 0.3), $x | 0$)
    line("q4", "q5", mark: (end: ">")); content((7, 0.3), $y | 0$)
    line("q5", "q6", mark: (end: ">")); content((9, 0.3), $y | 0$)
    line("q6", "q7", mark: (end: ">")); content((11, 0.3), $x | 0$)
    line("q7", "q8", mark: (end: ">")); content((13, 0.3), $x | 0$)
    line("q8", "q9", mark: (end: ">")); content((15, 0.3), $y | 1$) // Успешное распознавание!

    // Дуги возврата при ошибке (снизу)
    bezier("q2", "q2", (2, -1.5), (1.5, -1.5), mark: (end: ">")); content((2, -1.2), $y | 0$)
    bezier("q3", "q2", (3, -1), (2.5, -1), mark: (end: ">")); content((3, -0.6), $y | 0$)
    bezier("q4", "q1", (3, -1.5), (1, -1.5), mark: (end: ">")); content((3, -1.2), $x | 0$)
    bezier("q5", "q1", (4, -2.5), (2, -2.5), mark: (end: ">")); content((4, -2.2), $x | 0$)
    bezier("q6", "q2", (6, -2), (4, -2), mark: (end: ">")); content((6, -1.7), $y | 0$)
    bezier("q7", "q2", (7, -1.5), (5, -1.5), mark: (end: ">")); content((7, -1.2), $y | 0$)
    bezier("q8", "q1", (7, -3.5), (3, -3.5), mark: (end: ">")); content((7, -3.2), $x | 0$)
    bezier("q9", "q2", (9, -4.5), (5, -4.5), mark: (end: ">")); content((9, -4.2), $y | 0$)
    bezier("q9", "q3", (10, -4), (7, -4), mark: (end: ">")); content((10, -3.7), $x | 0$)
    
    // Петля ошибки на q1 (если пришла "х", а ждем "у")
    bezier("q1", "q1", (-1, -1), (-0.5, -1), mark: (end: ">")); content((-1, -0.6), $x | 0$)
  })
]

