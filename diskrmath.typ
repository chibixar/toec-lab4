  [$x$], [$q_1,0$], [$q_3,0$], [$q_4,0$], [$q_1,0$], [$q_3,0$], [$q_7,0$], [$q_8,0$], [$q_1,0$], [$q_3,0$],
  [$y$], [$q_2,0$], [$q_2,0$], [$q_2,0$], [$q_5,0$], [$q_6,0$], [$q_2,0$], [$q_2,0$], [$q_9,1$], [$q_2,0$]
)
